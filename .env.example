# Server (Express proxy) — keep keys server-side when possible
# Used for Gemma REST calls, chapter detection, and POST /api/gemini-live/token (recommended for Gemini Live).
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
PORT=3001

# Vite client
# Omit in local dev so the app uses same-origin `/api/...` (Vite proxies to port 3001).
# If you set http://localhost:3001, the Express server must allow CORS (this repo does).
# VITE_API_URL=http://localhost:3001

# Optional: browser-embedded key. Live sessions prefer server-minted tokens (GEMINI_API_KEY) because
# WebSocket handshakes may not send a referrer matching HTTP-referrer key restrictions.
VITE_GOOGLE_API_KEY=

# Optional: override Gemini Live model (default: gemini-2.5-flash-native-audio-preview-12-2025)
# VITE_GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
