# Server (Express proxy) — keep keys server-side when possible.
# GEMINI_API_KEY powers Gemini Live and the cloud Gemma OCR fallback for handwritten notes.
# ELEVENLABS_API_KEY powers lecture transcription, live captions, voice cloning, and TTS.
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
PORT=3001

# Local Ollama model for Gemma 4 lecture memory + chapter detection.
# Start the daemon with `ollama serve` (or run a model once with `ollama run <model>` to
# auto-start it), then `ollama pull <model>` so it is available locally.
# If you want Gemma 4 for lecture memory, set OLLAMA_MODEL to your installed Gemma 4 tag
# from `ollama list` (for example `gemma4:e4b`). If Ollama is unreachable, publishing
# still succeeds, but lecture memory stays pending or unavailable until Gemma 4 comes back.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b

# Vite client
# Omit in local dev so the app uses same-origin `/api/...` (Vite proxies to port 3001).
# If you set http://localhost:3001, the Express server must allow CORS (this repo does).
# VITE_API_URL=http://localhost:3001

# Optional: browser-embedded key. Live sessions prefer server-minted tokens
# (GEMINI_API_KEY) because WebSocket handshakes may not send a referrer matching
# HTTP-referrer key restrictions.
VITE_GOOGLE_API_KEY=

# Optional: override Gemini Live model (default: gemini-2.5-flash-native-audio-preview-12-2025)
# VITE_GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
